{
  "mcpServers": {
    "observatory-docker": {
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "/path/to/observatory/docker-compose.yml",
        "--profile",
        "mcp",
        "run",
        "--rm",
        "-i",
        "mcp-server"
      ]
    },
    "observatory-local": {
      "command": "node",
      "args": ["/path/to/observatory/packages/mcp-server/dist/index.js"],
      "env": {
        "OBSERVATION_SERVICE_URL": "http://localhost:52033",
        "OBSERVATION_TIMEOUT": "30"
      }
    }
  }
}
