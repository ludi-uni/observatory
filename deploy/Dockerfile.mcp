FROM node:22-bookworm-slim AS builder

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app
COPY .npmrc package.json pnpm-workspace.yaml pnpm-lock.yaml tsconfig.base.json ./
COPY packages/types ./packages/types
COPY packages/mcp-server ./packages/mcp-server

RUN pnpm install --frozen-lockfile=false --config.ignore-scripts=true
RUN pnpm --filter @observatory/types build
RUN pnpm --filter @observatory/mcp-server build
RUN pnpm deploy --filter @observatory/mcp-server --prod --legacy /out

FROM node:22-bookworm-slim

WORKDIR /app
COPY --from=builder /out /app

ENV NODE_ENV=production
ENV OBSERVATION_SERVICE_URL=http://observation-service:8080
ENV OBSERVATION_TIMEOUT=30

ENTRYPOINT ["node", "dist/index.js"]
