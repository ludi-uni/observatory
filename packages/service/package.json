    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@mozilla/readability": "^0.6.0",
    "@observatory/types": "workspace:*",
    "hono": "^4.8.3",
    "linkedom": "^0.18.12",
    "pg": "^8.16.0",
    "playwright": "1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/pg": "^8.15.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
