{
  "name": "@observatory/service",
  "version": "0.1.0",
  "description": "Observation Service for Observatory",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "observatory-service": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node --watch dist/index.js",
